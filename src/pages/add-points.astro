---
import Layout from '../layouts/Layout.astro';
import { supabase } from '../lib/supabase';

const userId = Astro.cookies.get('user_id')?.value;
if (!userId) return Astro.redirect('/');

let message = { text: '', type: '' };

// Procesar el envío de un solo clic
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const actionId = formData.get('action_id');
  const targetUserId = formData.get('target_user_id');

  if (typeof actionId === 'string' && typeof targetUserId === 'string') {
    const { error } = await supabase
      .from('activity_log')
      .insert([{ 
        user_id: targetUserId, 
        action_id: actionId 
      }]);

    if (error) {
      message = { text: 'Error al registrar la acción.', type: 'error' };
    } else {
      return Astro.redirect('/ranking');
    }
  }
}

// 1. Obtener datos
const [{ data: users }, { data: actions }] = await Promise.all([
  supabase.from('users').select('id, name').order('name'),
  supabase.from('actions').select('id, description, points, categories(name)').order('points', { ascending: false })
]);

// 2. Agrupar las acciones por categoría en el servidor para facilitar el renderizado
const categoriesMap = new Map();
actions?.forEach(action => {
  // @ts-ignore (Supabase typings para joins)
  const catName = action.categories.name;
  if (!categoriesMap.has(catName)) {
    categoriesMap.set(catName, []);
  }
  categoriesMap.get(catName).push(action);
});
---

<Layout title="Sumar Puntos">
  <div class="page-header fade-in">
    <h1>Añadir Puntos</h1>
    <p class="subtitle">Toca una acción para registrarla al instante</p>
  </div>

  {message.text && (
    <div class={`alert ${message.type}`}>{message.text}</div>
  )}

  <form method="POST" class="add-form fade-in" style="animation-delay: 0.1s;">
    <div class="field">
      <label>Participante</label>
      <div class="input-group">
        <select name="target_user_id" required class="premium-select">
          {users?.map(u => (
            <option value={u.id} selected={u.id === userId}>
              {u.name} {u.id === userId ? '(Tú)' : ''}
            </option>
          ))}
        </select>
        <div class="select-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
        </div>
      </div>
    </div>

    <div class="categories-container">
      {Array.from(categoriesMap.entries()).map(([catName, catActions]) => (
        <details class="category-card">
          <summary class="category-header">
            <span class="category-title">{catName}</span>
            <span class="chevron">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
            </span>
          </summary>
          
          <div class="actions-list">
            {catActions.map((action: any) => (
              <button 
                type="submit" 
                name="action_id" 
                value={action.id} 
                class="direct-action-btn"
              >
                <span class="desc">{action.description}</span>
                <span class={`pts-badge ${action.points > 0 ? 'pos' : 'neg'}`}>
                  {action.points > 0 ? '+' : ''}{action.points}
                </span>
              </button>
            ))}
          </div>
        </details>
      ))}
    </div>
  </form>
</Layout>

<style>
  .page-header { margin-bottom: 2rem; }
  h1 { margin-bottom: 0.25rem; font-weight: 800; }
  .subtitle { color: var(--text-dim); font-size: 0.95rem; }

  .field { margin-bottom: 2rem; }
  label { display: block; margin-bottom: 0.75rem; color: var(--text-dim); font-size: 0.9rem; font-weight: 600; }
  
  /* Select Premium */
  .input-group { position: relative; }
  .premium-select {
    width: 100%; 
    max-width: 100%; /* Evita que crezca más que la pantalla */
    appearance: none; 
    background: var(--surface);
    border: 1px solid rgba(255, 255, 255, 0.1); 
    color: #fff;
    /* Ajustamos el padding derecho a 2.5rem para dejar sitio al icono */
    padding: 1.1rem 2.5rem 1.1rem 1rem; 
    border-radius: 14px; 
    font-size: 1rem; 
    font-weight: 500;
    outline: none; 
    transition: all 0.3s ease; 
    cursor: pointer;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    
    /* El truco mágico para nombres largos: */
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .premium-select:focus { border-color: var(--primary); background: rgba(30, 41, 59, 0.9); }
  .select-icon { position: absolute; right: 1rem; top: 50%; transform: translateY(-50%); pointer-events: none; color: var(--text-dim); }

  /* Acordeón de Categorías */
  .categories-container { display: flex; flex-direction: column; gap: 1rem; padding-bottom: 2rem; }

  .category-card {
    background: var(--surface);
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.05);
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    overflow: hidden;
    transition: all 0.3s ease;
  }

  .category-header {
    padding: 1.25rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    list-style: none; /* Quita la flecha nativa */
    user-select: none;
    background: rgba(255, 255, 255, 0.02);
  }
  
  /* Quita la flecha nativa en Safari/Webkit */
  .category-header::-webkit-details-marker { display: none; }

  .category-title { font-weight: 700; font-size: 1.1rem; letter-spacing: 0.5px; text-transform: uppercase; color: var(--text); }
  
  .chevron { transition: transform 0.3s ease; color: var(--text-dim); display: flex; }
  
  /* Rota la flecha cuando el <details> está abierto */
  details[open] .chevron { transform: rotate(180deg); color: var(--primary); }
  details[open] { border-color: rgba(59, 130, 246, 0.3); }

  /* Lista de botones internos */
  .actions-list {
    padding: 0 1rem 1rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    animation: slideDown 0.2s ease-out;
  }

  /* El botón de acción directa */
  .direct-action-btn {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: rgba(15, 23, 42, 0.5); /* Fondo más oscuro que la tarjeta */
    border: 1px solid rgba(255, 255, 255, 0.05);
    padding: 1rem;
    border-radius: 12px;
    color: var(--text);
    cursor: pointer;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    text-align: left;
  }

  .direct-action-btn:hover { background: rgba(59, 130, 246, 0.1); border-color: rgba(59, 130, 246, 0.3); }
  
  .direct-action-btn:active {
    transform: scale(0.97);
    background: var(--primary);
    border-color: var(--primary);
  }

  .desc { font-weight: 500; font-size: 1rem; flex: 1; padding-right: 1rem; }
  
  .pts-badge { font-weight: 800; font-size: 0.95rem; padding: 4px 10px; border-radius: 20px; }
  .pos { background: rgba(16, 185, 129, 0.15); color: #10b981; }
  .neg { background: rgba(239, 68, 68, 0.15); color: #ef4444; }
  
  .direct-action-btn:active .pts-badge { background: rgba(255,255,255,0.2); color: white; }

  .alert { padding: 1rem; border-radius: 12px; margin-bottom: 1.5rem; text-align: center; }
  .error { background: rgba(239, 68, 68, 0.15); color: #fca5a5; border: 1px solid rgba(239, 68, 68, 0.3); }

  .fade-in { animation: fadeIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) both; }

  @keyframes fadeIn { from { opacity: 0; transform: translateY(15px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes slideDown { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }
</style>