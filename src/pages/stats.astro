---
import Layout from '../layouts/Layout.astro';
import { supabase } from '../lib/supabase';
import RadarChart from '../components/RadarChart.astro'; 

// 1. OBTENER DATOS
const [
  { data: users },
  { data: dailyStats },
  { data: categoryStats }
] = await Promise.all([
  supabase.from('users').select('name').order('name'),
  supabase.from('daily_stats').select('*'), 
  supabase.from('user_category_stats').select('*') 
]);

const userNames = (users || []).map(u => u.name);

// --- DATOS LÍNEAS (EVOLUCIÓN ACUMULADA) ---
const dates = [...new Set((dailyStats || []).map(s => new Date(s.date).toLocaleDateString('es-ES', { day: '2-digit', month: 'short' })))];

const lineDatasets = userNames.map(userName => {
  const hash = userName.split('').reduce((a, b) => { a = ((a << 5) - a) + b.charCodeAt(0); return a & a }, 0);
  const color = `hsl(${Math.abs(hash) % 360}, 70%, 60%)`;
  
  let puntuacionAcumulada = 0; 

  return {
    label: userName,
    data: dates.map(date => {
      const entry = (dailyStats || []).find(s => s.name === userName && new Date(s.date).toLocaleDateString('es-ES', { day: '2-digit', month: 'short' }) === date);
      puntuacionAcumulada += entry ? Number(entry.points_day) : 0;
      return puntuacionAcumulada;
    }),
    borderColor: color,
    backgroundColor: color,
    tension: 0.3,
    borderWidth: 2,
    pointRadius: 4, 
    pointHoverRadius: 6,
    pointBackgroundColor: color
  };
});

// --- DATOS QUESO (DISTRIBUCIÓN IMPACTO) ---
const pieDataMap = new Map();
(categoryStats || []).forEach(stat => {
  const current = pieDataMap.get(stat.category_name) || 0;
  pieDataMap.set(stat.category_name, current + Math.abs(stat.total_points)); 
});

const pieLabels = Array.from(pieDataMap.keys());
const pieValues = Array.from(pieDataMap.values());
const pieColors = pieLabels.map((_, i) => `hsl(${(i * 360) / pieLabels.length}, 75%, 55%)`);

// --- SERIALIZACIÓN ---
const serializedData = {
  categories: [...new Set((categoryStats || []).map(c => c.category_name))],
  categoryStats: categoryStats || [],
  userNames
};

const pageChartData = { dates, lineDatasets, pieLabels, pieValues, pieColors };
---

<Layout title="Estadísticas">
  <div class="page-header fade-in">
    <h1>Estadísticas</h1>
    <p class="subtitle">Seguimiento detallado de la competición</p>
  </div>

  <section class="stat-section fade-in" style="animation-delay: 0.1s;">
    <h2>Análisis Global</h2>
    
    <div class="charts-grid">
      <div class="card chart-wrapper">
        <h3 class="chart-title">Carrera de Puntos</h3>
        <div class="canvas-container">
          <canvas id="groupChart"></canvas>
        </div>
      </div>

      <div class="card chart-wrapper">
        <h3 class="chart-title">Distribución de Actividad</h3>
        <div class="canvas-container">
          <canvas id="pieChart"></canvas>
        </div>
      </div>
    </div>
  </section>

  <section class="stat-section fade-in" style="animation-delay: 0.2s;">
    <h2>Análisis de Perfil</h2>
    <RadarChart serializedData={serializedData} />
  </section>
</Layout>

<script is:inline src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script define:vars={{ data: pageChartData }}>
  document.addEventListener('DOMContentLoaded', () => {
    Chart.defaults.color = '#94a3b8';
    Chart.defaults.font.family = "'Inter', system-ui, sans-serif";

    const ctxGroup = document.getElementById('groupChart');
    if (ctxGroup) {
      new Chart(ctxGroup, {
        type: 'line',
        data: { labels: data.dates, datasets: data.lineDatasets },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: { 
            legend: { position: 'bottom', labels: { usePointStyle: true, boxWidth: 8, padding: 20 } } 
          },
          scales: { 
            y: { grid: { color: 'rgba(255,255,255,0.05)' } }, 
            x: { grid: { display: false } } 
          }
        }
      });
    }

    const ctxPie = document.getElementById('pieChart');
    if (ctxPie) {
      new Chart(ctxPie, {
        type: 'doughnut',
        data: {
          labels: data.pieLabels,
          datasets: [{ data: data.pieValues, backgroundColor: data.pieColors, borderWidth: 2, borderColor: '#161c2d' }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          cutout: '65%',
          plugins: {
            legend: { position: 'bottom', labels: { usePointStyle: true, padding: 20 } },
            tooltip: {
              callbacks: {
                label: function(context) {
                  let total = context.dataset.data.reduce((a, b) => a + b, 0);
                  let percentage = Math.round((context.parsed / total) * 100) + '%';
                  return `${context.label}: ${percentage} (${context.parsed} pts)`;
                }
              }
            }
          }
        }
      });
    }
  });
</script>

<style>
  .page-header { 
    margin-bottom: 3.5rem; 
    text-align: center; 
  }
  
  h1 { 
    font-weight: 800; 
    font-size: 2.5rem;
    background: linear-gradient(to right, #fff, #94a3b8);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  
  .subtitle { color: #94a3b8; font-size: 1.1rem; margin-top: 0.5rem; }
  
  .stat-section { margin-bottom: 5rem; }
  
  .stat-section h2 { 
    font-size: 1.4rem; 
    margin-bottom: 2rem; 
    color: #fff; 
    padding-left: 1rem; 
    border-left: 4px solid #3b82f6;
  }
  
  .charts-grid { 
    display: grid; 
    grid-template-columns: 1fr; 
    gap: 2.5rem; 
  }
  
  @media (min-width: 1024px) { 
    .charts-grid { grid-template-columns: 3fr 2fr; } 
  }
  
  .chart-wrapper { 
    background: linear-gradient(145deg, rgba(30,41,59,0.8), rgba(15,23,42,0.9));
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255,255,255,0.1); 
    border-radius: 24px; 
    padding: 1.75rem; 
    box-shadow: 0 20px 40px rgba(0,0,0,0.3);
  }

  .canvas-container {
    position: relative;
    height: 320px; /* Altura fija para que la leyenda no se escape */
    width: 100%;
  }
  
  .chart-title { 
    font-size: 0.9rem; 
    color: #94a3b8; 
    text-transform: uppercase; 
    letter-spacing: 1.5px; 
    margin-bottom: 1.5rem; 
    text-align: center; 
    font-weight: 700;
  }
  
  .fade-in { 
    animation: fadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) both; 
  }
  
  @keyframes fadeIn { 
    from { opacity: 0; transform: translateY(30px); } 
    to { opacity: 1; transform: translateY(0); } 
  }
</style>