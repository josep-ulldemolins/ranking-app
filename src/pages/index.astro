---
import Layout from '../layouts/Layout.astro';
import { supabase } from '../lib/supabase';

if (Astro.cookies.has('user_id')) {
  return Astro.redirect('/ranking');
}

let errorMessage = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const userId = formData.get('user_id');

  if (typeof userId === 'string' && userId.trim() !== '') {
    Astro.cookies.set('user_id', userId, {
      path: '/',
      maxAge: 60 * 60 * 24 * 30, 
      httpOnly: true,
      secure: import.meta.env.PROD,
      sameSite: 'lax'
    });
    return Astro.redirect('/ranking');
  } else {
    errorMessage = 'Selecciona un participante válido.';
  }
}

const { data: users } = await supabase
  .from('users')
  .select('id, name')
  .order('name');
---

<Layout title="Entrar">
  <div class="login-wrapper">
    <div class="glass-card fade-in">
      <div class="icon-header">🌴</div>
      <h1>Liga Vacaciones</h1>
      <p class="subtitle">Selecciona tu perfil para entrar</p>
      
      {errorMessage && <div class="error-banner">{errorMessage}</div>}
      
      <form method="POST" class="login-form">
        <div class="input-group">
          <select name="user_id" required class="premium-select">
            <option value="" disabled selected>Elige tu nombre...</option>
            {users?.map(user => (
              <option value={user.id}>{user.name}</option>
            ))}
          </select>
          <div class="select-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
          </div>
        </div>

        <button type="submit" class="btn-premium">
          <span>Entrar a la Liga</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </button>
      </form>
    </div>
  </div>
</Layout>

<style>
  .login-wrapper {
    min-height: 85vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }

  .glass-card {
    background: rgba(30, 41, 59, 0.7);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 24px;
    padding: 2.5rem 1.5rem;
    width: 100%;
    max-width: 400px;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    text-align: center;
  }

  .icon-header {
    font-size: 3.5rem;
    margin-bottom: 0.5rem;
    filter: drop-shadow(0 4px 6px rgba(0,0,0,0.2));
  }

  h1 {
    font-size: 1.8rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
    background: linear-gradient(to right, #fff, #94a3b8);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .subtitle {
    color: var(--text-dim);
    font-size: 0.95rem;
    margin-bottom: 2rem;
  }

  .error-banner {
    background: rgba(239, 68, 68, 0.15);
    color: #fca5a5;
    padding: 0.75rem;
    border-radius: 12px;
    border: 1px solid rgba(239, 68, 68, 0.3);
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
  }

  .login-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .input-group {
    position: relative;
  }

  .premium-select {
    width: 100%;
    appearance: none;
    background: rgba(15, 23, 42, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: #fff;
    padding: 1.1rem 1rem;
    border-radius: 14px;
    font-size: 1rem;
    font-weight: 500;
    outline: none;
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .premium-select:focus {
    border-color: var(--primary);
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.2);
    background: rgba(15, 23, 42, 0.9);
  }

  .select-icon {
    position: absolute;
    right: 1rem;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
    color: var(--text-dim);
  }

  .btn-premium {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
    color: white;
    border: none;
    padding: 1.1rem;
    border-radius: 14px;
    font-size: 1.05rem;
    font-weight: 700;
    cursor: pointer;
    box-shadow: 0 10px 20px -5px rgba(59, 130, 246, 0.5);
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .btn-premium:hover {
    transform: translateY(-2px);
    box-shadow: 0 15px 25px -5px rgba(59, 130, 246, 0.6);
  }

  .btn-premium:active {
    transform: translateY(1px) scale(0.97);
    box-shadow: 0 5px 10px -5px rgba(59, 130, 246, 0.5);
  }

  .fade-in {
    animation: fadeIn 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>